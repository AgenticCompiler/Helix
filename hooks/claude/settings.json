{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/helix-hooks/pretooluse_guard.py",
              "--policy",
              "${CLAUDE_PROJECT_DIR}/.claude/helix-hooks/policy.json"
            ]
          }
        ]
      }
    ]
  }
}
