{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CODEX_PROJECT_DIR}/.codex/triton-agent-hooks/tool_trace_hook.py\" --policy \"${CODEX_PROJECT_DIR}/.codex/triton-agent-hooks/policy.json\" --event PreToolUse"
          },
          {
            "type": "command",
            "command": "python3 \"${CODEX_PROJECT_DIR}/.codex/triton-agent-hooks/pretooluse_guard.py\" --policy \"${CODEX_PROJECT_DIR}/.codex/triton-agent-hooks/policy.json\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CODEX_PROJECT_DIR}/.codex/triton-agent-hooks/tool_trace_hook.py\" --policy \"${CODEX_PROJECT_DIR}/.codex/triton-agent-hooks/policy.json\" --event PostToolUse"
          }
        ]
      }
    ]
  }
}
